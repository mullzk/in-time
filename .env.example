# Environment contract. Copy to .env for local development; never commit .env.
# In production these come from the Vault-rendered EnvironmentFile, not a file
# in the repo. Marker meaning: [secret] must come from Vault, [config] is plain.

# [secret] required. Prod: from Vault. A long, random string.
DJANGO_SECRET_KEY=change-me

# [config] optional, default false. Dev only — MUST stay false in production.
DJANGO_DEBUG=true

# [config] required. Comma-separated hostnames/domains the app may serve.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# [secret] required. mysql://user:password@host:port/database (MariaDB).
DATABASE_URL=mysql://in_time:in_time@127.0.0.1:3306/in_time

# [config] required. Persistent data dir, shared by app and build commands.
# Prod: a per-instance dir so two instances on one host (e.g. staging + test)
# never collide, e.g. /var/lib/in-time/<app-name>. Dev: a local path.
IN_TIME_DATA_DIR=./data

# DJANGO_SETTINGS_MODULE is optional: manage.py/wsgi.py default it to
# config.settings. Set it explicitly in the prod EnvironmentFile if desired.
